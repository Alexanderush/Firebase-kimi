# Kimi AI Agency Platform — Environment Variables
# ================================================
# For Firebase App Hosting, these should be configured as:
#   - Secrets: via Firebase Console → App Hosting → Secrets (stored in Google Cloud Secret Manager)
#   - Public vars: via apphosting.yaml directly
#
# For local development, copy this file to .env and fill in the values.

# ── Database (External PostgreSQL — e.g., Neon.tech, Supabase, Cloud SQL) ──
DATABASE_URL="postgresql://user:password@host:5432/kimi_db?sslmode=require"

# ── Authentication ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-with-openssl-rand-base64-32"

# ── Kimi AI (Moonshot AI via NVIDIA NIM) ──
NVIDIA_API_KEY="your-nvidia-api-key"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
KIMI_MODEL="moonshotai/kimi-k2.5"

# ── Google OAuth (for Google tool connections: Gmail, Calendar, Sheets) ──
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Yahoo OAuth ──
YAHOO_CLIENT_ID="your-yahoo-client-id"
YAHOO_CLIENT_SECRET="your-yahoo-client-secret"

# ── Meta / WhatsApp ──
META_CLIENT_ID="your-meta-client-id"
META_CLIENT_SECRET="your-meta-client-secret"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-verify-token"

# ── Prisma ──
PRISMA_CLIENT_ENGINE_TYPE="library"
